@page "/weather"
@rendermode InteractiveServer
@inject HttpClient Http

<PageTitle>Погода — NewsPortal</PageTitle>

<div class="container py-5">
    @* Заголовок в новом стиле *@
    <div class="mb-5 animate-fade">
        <h1 class="fw-bold" style="color: #800020; font-size: 2.5rem;">Погода в городах</h1>
        <p class="text-muted">Актуальные данные метеослужб на текущий момент</p>
        <div style="height: 3px; width: 60px; background-color: #800020; margin-top: 10px;"></div>
    </div>

    @* Обработка ошибок *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger shadow-sm" style="border-radius: 12px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Ошибка:</strong> @errorMessage
        </div>
    }

    @* Индикатор загрузки *@
    @if (cityWeatherList.Count == 0 && string.IsNullOrEmpty(errorMessage))
    {
        <div class="text-center py-5">
            <div class="spinner-border" style="color: #800020; width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted">Запрашиваем данные по городам...</p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var (city, index) in cityWeatherList.Select((v, i) => (v, i)))
            {
                <div class="col-md-6 col-lg-3 mb-4">
                    <div class="card h-100 border-0 shadow-sm animate-fade text-center news-card-hover"
                         style="border-radius: 20px; background: #ffffff; animation-delay: @(index * 0.1)s;">

                        <div class="card-body p-4">
                            <div class="mb-3">
                                <span class="badge rounded-pill px-3 py-2" style="background-color: rgba(128, 0, 32, 0.05); color: #800020; font-weight: 600; letter-spacing: 0.5px;">
                                    @city.DisplayName
                                </span>
                            </div>

                            @* Температура: Бордовая для плюса *@
                            <h2 class="display-4 fw-bold mb-0" style="color: @(city.Temp.Contains("-") ? "#2d3436" : "#800020"); letter-spacing: -2px;">
                                @(double.Parse(city.Temp) > 0 ? "+" : "")@city.Temp°C
                            </h2>

                            <div class="mt-4 pt-3 border-top border-light">
                                <p class="text-muted small mb-0">
                                    <i class="bi bi-wind me-1"></i> Ветер: <strong>@city.WindSpeed</strong> км/ч
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<CityWeather> cityWeatherList = new();
    private string? errorMessage;

    private List<CityCoords> cities = new()
    {
        new CityCoords("Москва", 55.75, 37.61),
        new CityCoords("Санкт-Петербург", 59.93, 30.31),
        new CityCoords("Калининград", 54.71, 20.51),
        new CityCoords("Екатеринбург", 56.83, 60.61)
    };

    protected override async Task OnInitializedAsync()
    {
        foreach (var city in cities)
        {
            try
            {
                var url = $"https://api.open-meteo.com/v1/forecast?latitude={city.Lat.ToString(System.Globalization.CultureInfo.InvariantCulture)}&longitude={city.Lon.ToString(System.Globalization.CultureInfo.InvariantCulture)}&current_weather=true";

                var response = await Http.GetFromJsonAsync<OpenMeteoResponse>(url);

                if (response?.current_weather != null)
                {
                    cityWeatherList.Add(new CityWeather
                        {
                            DisplayName = city.Name,
                            Temp = Math.Round(response.current_weather.temperature).ToString(),
                            WindSpeed = Math.Round(response.current_weather.windspeed).ToString()
                        });

                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                errorMessage = "Не удалось загрузить данные. Проверьте интернет.";
                Console.WriteLine($"Ошибка: {ex.Message}");
            }
        }
    }

    public record CityCoords(string Name, double Lat, double Lon);

    public class CityWeather
    {
        public string DisplayName { get; set; } = "";
        public string Temp { get; set; } = "";
        public string WindSpeed { get; set; } = "";
    }

    public class OpenMeteoResponse
    {
        public CurrentWeather current_weather { get; set; } = new();
    }

    public class CurrentWeather
    {
        public double temperature { get; set; }
        public double windspeed { get; set; }
    }
}

<style>
    /* Анимация и эффекты */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade {
        animation: fadeInUp 0.5s ease-out backwards;
    }

    .news-card-hover {
        transition: all 0.3s ease;
    }

        .news-card-hover:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(128, 0, 32, 0.1) !important;
        }
</style>